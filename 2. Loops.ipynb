   "source": [
    "## Sum of n natural numbers using while loop\n",
    "num=float(input(\"Enter number of natural numbers to be considered:\"))\n",
    "sum=0\n",
    "count=1 ## starting number\n",
    "while count<=num:\n",
    "    sum=sum+count\n",
    "    count=count+1\n",
    "print(\"Sum of\",num,\"natural numbers are:\",sum)\n",
    "\n"
   ]
  }
