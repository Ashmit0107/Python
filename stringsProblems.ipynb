    "# check if a string is palindrome or not\n",
    "\n",
    "def is_string_palindrome(s):\n",
    "    return s==s[::-1]\n",
    "print(\"Check the word 'MADAM' for palindrome:\",is_string_palindrome(\"madam\"))"
   ]
  }
